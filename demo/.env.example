# Required: HMAC key for challenge signing (any random string)
MPP_SECRET_KEY=degen-oracle-dev-secret-change-me

# Optional: OpenAI key for LLM-generated takes (falls back to deterministic)
# OPENAI_API_KEY=sk-...

# Optional: deployed PrivacyEscrow address
# ESCROW_CONTRACT=0x...

# Optional: server wallet address (recipient of session payments)
# RECIPIENT=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# Optional: TIP-20 token address (pathUSD)
# CURRENCY=0x20c0000000000000000000000000000000000000

# Optional: price per query
# PRICE=0.01
